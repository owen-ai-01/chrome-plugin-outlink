{
  "manifest_version": 3,
  "name": "Outlink Collector",
  "description": "Collect, analyze, and publish outlink resources.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "sidePanel",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://www.producthunt.com/*",
    "https://sem.3ue.co/*",
    "https://ahrefs.com/*",
    "https://*.ahrefs.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background-v2.js",
    "type": "module"
  },
  "action": {
    "default_title": "Outlink Collector"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ahrefs.com/*",
        "https://*.ahrefs.com/*",
        "https://sem.3ue.co/*"
      ],
      "js": [
        "content/interceptor.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.producthunt.com/*"
      ],
      "js": [
        "content/producthunt-publisher.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "https://ahrefs.com/*",
        "https://*.ahrefs.com/*",
        "https://sem.3ue.co/*",
        "https://www.producthunt.com/*"
      ],
      "js": [
        "content/blog-comment-publisher.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/page-hook.js"
      ],
      "matches": [
        "https://ahrefs.com/*",
        "https://*.ahrefs.com/*",
        "https://sem.3ue.co/*"
      ]
    }
  ]
}
